# ─────────────────────────────────────────────
#  FocusFlow AI — Environment Variables
#  Copy to .env.local and fill in your values
# ─────────────────────────────────────────────

# Supabase (from supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...

# Anthropic — PRIMARY AI (console.anthropic.com)
# App uses Claude first. If quota hits, Groq kicks in automatically.
ANTHROPIC_API_KEY=sk-ant-...your_key...

# Groq — FALLBACK AI (console.groq.com) — free tier available
# Used automatically if Anthropic is unavailable or quota exceeded
GROQ_API_KEY=gsk_...your_key...

# Upstash Redis — rate limiting + AI response cache (upstash.com)
UPSTASH_REDIS_REST_URL=https://...your_redis_url...
UPSTASH_REDIS_REST_TOKEN=AX...your_token...

# Web Push Notifications — VAPID keys
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BN...your_public_key...
VAPID_PRIVATE_KEY=...your_private_key...
VAPID_SUBJECT=mailto:you@example.com

# App URL (use http://localhost:3000 for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
